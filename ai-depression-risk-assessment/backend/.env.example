# ─────────────────────────────────────────────────────────────────────────────
# MindEase — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your real values below.
#   3. Never commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get your URI from: Atlas → Database → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?...
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mindease?retryWrites=true&w=majority&appName=<AppName>

# ── JWT Secret Key ────────────────────────────────────────────────────────────
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_secret

# ── Flask Server ──────────────────────────────────────────────────────────────
DEBUG=False
PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Development: ALLOWED_ORIGINS=*
# Production:  ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# ── Pagination ────────────────────────────────────────────────────────────────
HISTORY_PAGE_SIZE=10
